{
  "name": "tesseract-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/gen-llms-docs.mjs && node scripts/generate-sitemap.js",
    "build": "tsc -b && vite-react-ssg build",
    "build:ssg": "tsc -b && vite-react-ssg build",
    "build:analyze": "tsc -b && vite-react-ssg build && start dist/stats.html",
    "lint": "eslint .",
    "preview": "vite preview",
    "sanity": "sanity",
    "typegen": "sanity typegen generate",
    "studio": "sanity dev"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "react": "19.2.2",
    "react-dom": "19.2.2",
    "react-router-dom": "^7.5.3",
    "vite-plugin-compression": "^0.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.14.0",
    "vite": "^6.3.0",
    "vite-react-ssg": "^0.9.0"
  }
}
